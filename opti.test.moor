: fill0		<<< for >|>| c! 1+ over _ _ ;
: fill2		( :a :n :c ) :a :n for | :c >< c! 1+ over _ return ;
: fill3		( :a :n :c ) :n for :c emit over return ;
: fill4		( :a :n :c ) :n if :c emit then return ;
: emit1		41 42 43 emit emit emit cr ;

: sar0		70 | 1 sar emit emit ;
: sar01		1 70 | >>> sar emit emit ;
: sar1		200 3 sar emit cr ;
: sar2		1 200 | { 3 sar } + 201 - emit cr ;
: sar3		3 for 200 3 sar I +  emit over cr ;

: andor1	1 3 and 2 or 40 + emit ;
: orand1	1 3 or 2 and 40 + emit ;
: pp1		1 3 + 2 + 40 + emit ;
: less1		| 35 < if 1+ else 1- then emit cr ;

: mul1		2 3 * ;


: uemit1	4351 uemit cr ;
: u2emit1	7 9 u2emit cr ;
: u2emit2	407 6lsb u2emit cr ;
: uemit3
  | 80 < if 41 else
  | 800 < if 42 else
  | 10000 < if 43 else
  | 110000 < if 44 else
  45 then then then then emit _ cr ;

: uemit4
  | 80 < if _ 41 emit  else
  | 800 < if _ 42 43 emit emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit else
  | 10000 < if _ 43 44 45 emit emit emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit else
  | 110000 < if _ 44 45 46 47 emit emit emit emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit 41 emit else
  _ 45 emit then then then then cr ;

: 6lsb0 | 3f and >< 2/ 2/ 2/ 2/ 2/ 2/ ;
: 6lsb1 | >< 2/ ;
: uemit0
  | 80 < if _ 41 emit else
  | 800 < if _ 42 emit else
  | 10000 < if _ 43 emit else
  | 110000 < if | >< 1+ emit emit else
  _ 30 emit then 31 emit then 32 emit then 33 emit then cr ;

\\ TODO: branch offsets wrong !!!
: ++ 1+ 1+ ;

: if5	| if ++ then     | if ++ then ;

: if50  | if 1+ 1+ 1+ else 1+ 1+ then ;
: if51  | if ++ ++ 1+ else 1+ 1+ then ;
: if52  | if if50 else 1+ 1+ then ;
: if53  | if if51 else 1+ 1+ then ;
: if55  | if ++ ++ else ++ then ;

: if59  | if 1+ else 1+ then ;
: if6	| if 1+ 1+ then  | if 1+ 1+ then ;
: if7   | if if5 else then 41 + emit cr  ;
: if8   | if | if ++ then 30 + emit cr noop else 30 + emit cr then noop ;

: if90  | if 5 else 6 then ;
: if9   | if if90 else 9 then 30 + emit ;

: (if111)	if 41 else 42 then ;
: if110 	| if (if111) else (if111) then ;
: if11		1 if110 0 if110 >< emit emit cr ;

: for0		3 | for 41 emit over 40 + emit cr ;
: for00		3 for 41 emit over cr ;
: for01		3 | for I 41 + noop emit over 40 + emit cr ;
: for1		3 for | uemit cr over _ cr ;
: for11		3 for | emit cr noop over _ cr ;
: for2		( :c ) 1 for :c emit over return ;
: for3		3 for 2 for 41 I + emit over cr over cr ;
: for4		3 for I for 41 emit over cr over ;
: for5		3 for I | for | I + 41 + emit over _ cr over ;
: for6		3 for I | for | I - 41 + emit over _ cr over ;

: for7	0 0 ( :row :col )
	3 | for | I - :row!
		3 | for | I - :col! 
			:row 41 + emit :col 30 + emit bl emit
		over _
		cr
	over _
	return
;

: for8  1 ( :aaa )
	3 for I
		3 for | I 2 :aaa!
			+ 41 + :aaa + emit
		over _
		cr
	over 
	return 
;

: for9  3 2 ( :row :col )
	3 | for | I - :row!
		3 | for | I 2 :col!
			+ 41 + :col + emit
		over _
		cr
	over _
	cr
	return 
;

: while1	1 begin 30 emit while 33 emit 0 repeat 39 emit cr ;
: until1	-1 begin 30 emit 1+ | until _ cr ;
: again1	begin 30 emit 1 break again then cr ;

:: rows91 3 var
:: cols91 5 var
:: MM adr
	41 , 42 , 43 , 44 , 45 ,
	46 , 47 , 48 , 49 , 4a ,
	4b , 4c , 4d , 4e , 4f ,
: 'MM	( :row :col )
	:row cols91 @ * :col + cells MM +		\\ CELLS is incorrect (SHL?)
	return ;

: for91	0 0 ( :row :col )
	rows91 @       | for | I - :row!
		bl emit
		cols91 @       | for | I - :col! 
			\ bl emit :row 30 + emit :col 30 + emit
			:row :col 'MM c@ emit
		over _
		cr
	over _
	return
;

: plus1		1 | 2 | + + 41 + emit _ cr ;
: plus2		41 | 1+ emit emit cr ;

: loc1		30 ( :aaa ) 60 30 - :aaa! 60 60 - _ :aaa emit cr return ;

: noop1 ++ ;
: noop2 noop ;
: noop3 ;

: .str1	noop ." STRING111" cr ;
:: 'str1 adr 07 c, 31 c, 32 c, 33 c, 41 c, 42 c, 43 c, 0a c,
: type1	[ 'str1 literal ] 1+ 7 type ;
: type2	[ 'str1 literal ] count type ;
: type3 ." 01234567890123456789012345678901234567890123456789" cr ;

:: (var) 42 var
: var0	(var) ;
: var1	(var) @ emit cr ;

:: (val) 42 val
: val0	(val) emit ;

: abort0	red 41 emit green 42 emit norm cr ;
: abort1	abort" Optimized abort" ;
: abort2	0 ( :flag )  :flag if abort" Optimized abort 2" then 30 emit cr return ;
: raise1	raise ;

: spill1	+ ;
: spill2	1+ + ;
: spill3	1 2 spill1 ;
: spill4	1 2 spill2 ;
: spill5	30 | { a random } _ + emit cr ;
: spill60	>| + 2 3 + ;
: spill6	1 2 || spill60 30 + + + + + emit cr ;

