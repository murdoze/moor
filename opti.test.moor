: fib		| if 0 1 >>> for >| + >< over _ then ;
: fib3		| if 0 1 >>> for >| + >< over _ then | 1+ ;
: res3		1 | 1+ >| ;
: nup		>r _ r> ;
: swap2		0 <<< <<< nup ;
: lswap		( :c :d ) :c :d :c! :d! :c :d return ;
: -lswap	( :c :d ) :c :d :c! :d! :d :c return ;
: onep		| 1+ 1+ 1+ >< - ;
: cset		1 3333 c! ;
: if0		0 if then ;
: if1		1 2 - if 0 else 1 then 30 + emit cr ;
: if2		1 2 < if 0 else 1 then 30 + emit cr ;
